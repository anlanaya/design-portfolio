---
import { spaces, styles } from '../data/categories';
---

<!-- 浮动添加按钮 -->
<button id="add-case-fab" class="fixed bottom-20 md:bottom-8 right-4 md:right-8 z-30 w-14 h-14 bg-accent-900 text-white rounded-full shadow-lg hover:bg-accent-800 hover:scale-110 active:scale-95 transition-all duration-200 flex items-center justify-center text-2xl font-light" title="添加案例" aria-label="添加案例">
  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
</button>

<!-- 侧滑面板 -->
<div id="add-case-panel" class="fixed inset-y-0 right-0 z-50 w-full max-w-md bg-white shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col">
  <!-- 面板头部 -->
  <div class="flex items-center justify-between px-6 py-4 border-b border-accent-100">
    <h2 class="text-lg font-display font-semibold text-accent-900">+ 添加案例</h2>
    <button id="close-panel" class="p-2 text-accent-400 hover:text-accent-900 transition-colors" aria-label="关闭">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- 面板内容（可滚动） -->
  <div class="flex-1 overflow-y-auto px-6 py-4 space-y-4">
    <!-- 标题 -->
    <div>
      <label class="block text-sm font-medium text-accent-500 mb-1">📋 案例标题 *</label>
      <input type="text" id="panel-title" placeholder="如：纯白叙事 · 现代极简客厅"
        class="w-full px-3 py-2 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
    </div>

    <!-- 描述 -->
    <div>
      <label class="block text-sm font-medium text-accent-500 mb-1">📝 简短描述 *</label>
      <textarea id="panel-description" rows="2" placeholder="一句话描述这个案例..."
        class="w-full px-3 py-2 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors resize-none"></textarea>
    </div>

    <!-- 来源链接 -->
    <div>
      <label class="block text-sm font-medium text-accent-500 mb-1">🔗 来源链接</label>
      <input type="url" id="panel-sourceUrl" placeholder="直接粘贴小红书/抖音链接"
        class="w-full px-3 py-2 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
      <div class="flex gap-1 mt-2">
        <button class="panel-platform-btn px-3 py-1 border rounded-full text-xs transition-colors bg-accent-900 text-white" data-platform="xiaohongshu">📕 小红书</button>
        <button class="panel-platform-btn px-3 py-1 border rounded-full text-xs transition-colors" data-platform="douyin">🎵 抖音</button>
        <button class="panel-platform-btn px-3 py-1 border rounded-full text-xs transition-colors" data-platform="original">✨ 原创</button>
      </div>
    </div>

    <!-- 面积 + 地点 -->
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-sm font-medium text-accent-500 mb-1">📐 面积</label>
        <input type="number" id="panel-area" placeholder="80㎡"
          class="w-full px-3 py-2 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
      </div>
      <div>
        <label class="block text-sm font-medium text-accent-500 mb-1">📍 地点</label>
        <input type="text" id="panel-location" placeholder="上海"
          class="w-full px-3 py-2 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
      </div>
    </div>

    <!-- 封面 -->
    <div>
      <label class="block text-sm font-medium text-accent-500 mb-1">🖼️ 封面图 URL</label>
      <input type="url" id="panel-cover" placeholder="https://..."
        class="w-full px-3 py-2 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
    </div>

    <!-- 空间标签 -->
    <div>
      <label class="block text-sm font-medium text-accent-500 mb-1">🏠 空间 *</label>
      <div class="flex flex-wrap gap-1.5" id="panel-spaces-tags">
        {spaces.map(space => (
          <button class="panel-tag-btn px-2.5 py-1 border rounded-full text-xs transition-colors" data-slug={space.slug}>{space.label}</button>
        ))}
      </div>
    </div>

    <!-- 风格标签 -->
    <div>
      <label class="block text-sm font-medium text-accent-500 mb-1">🎨 风格 *</label>
      <div class="flex flex-wrap gap-1.5" id="panel-styles-tags">
        {styles.map(style => (
          <button class="panel-tag-btn px-2.5 py-1 border rounded-full text-xs transition-colors" data-slug={style.slug}>{style.label}</button>
        ))}
      </div>
    </div>

    <!-- 密码 -->
    <div>
      <label class="block text-sm font-medium text-accent-500 mb-1">🔐 管理密码</label>
      <input type="password" id="panel-password" placeholder="输入密码"
        class="w-full px-3 py-2 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
    </div>
  </div>

  <!-- 底部按钮 -->
  <div class="px-6 py-4 border-t border-accent-100">
    <p id="panel-status" class="text-xs mb-2 hidden"></p>
    <button id="panel-save" class="w-full py-3 bg-accent-900 text-white text-sm font-medium rounded-lg hover:bg-accent-800 transition-colors">
      保存案例
    </button>
  </div>
</div>

<!-- 遮罩层 -->
<div id="add-case-overlay" class="fixed inset-0 z-40 bg-black/40 hidden transition-opacity"></div>

<style>
  #add-case-panel.open { transform: translateX(0); }
  .panel-tag-btn.selected { background: #293430; color: #fff; border-color: #293430; }
  .panel-platform-btn.selected { background: #293430; color: #fff; border-color: #293430; }
</style>

<script src="/add-case-panel.js" is:inline></script>
