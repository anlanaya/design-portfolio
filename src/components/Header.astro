---
import { spaces, styles } from '../data/categories';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-sm border-b border-accent-100">
  <nav class="max-w-8xl mx-auto px-4 md:px-8 h-16 md:h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="text-xl md:text-2xl font-display font-bold text-accent-900 tracking-tight hover:text-primary-600 transition-colors">
      设计案例库
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-1">
      <a href="/" class:list={['nav-link', { 'nav-link-active': currentPath === '/' }]}>
        首页
      </a>

      <!-- 空间下拉 -->
      <div class="relative group">
        <button class="nav-link flex items-center gap-1" class:list={['nav-link', { 'nav-link-active': currentPath.startsWith('/spaces/') }]}>
          按空间浏览
          <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-1 w-56 bg-white border border-accent-100 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
          {spaces.map((space) => (
            <a href={`/spaces/${space.slug}`} class="block px-4 py-2.5 text-sm text-accent-700 hover:bg-accent-50 hover:text-accent-900 transition-colors">
              {space.label}
            </a>
          ))}
        </div>
      </div>

      <!-- 风格下拉 -->
      <div class="relative group">
        <button class="nav-link flex items-center gap-1" class:list={['nav-link', { 'nav-link-active': currentPath.startsWith('/styles/') }]}>
          按风格浏览
          <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-1 w-56 bg-white border border-accent-100 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
          {styles.map((style) => (
            <a href={`/styles/${style.slug}`} class="block px-4 py-2.5 text-sm text-accent-700 hover:bg-accent-50 hover:text-accent-900 transition-colors">
              {style.label}
            </a>
          ))}
        </div>
      </div>

      <a href="/about" class:list={['nav-link', { 'nav-link-active': currentPath === '/about' }]}>
        关于
      </a>
      <a href="/contact" class:list={['nav-link', { 'nav-link-active': currentPath === '/contact' }]}>
        联系
      </a>
      <a href="/admin" class="px-3 py-1.5 ml-2 text-xs font-medium bg-accent-900 text-white rounded-full hover:bg-accent-800 transition-colors">
        + 添加
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden p-2 text-accent-600 hover:text-accent-900" aria-label="菜单">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="6" x2="20" y2="6" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="18" x2="20" y2="18" />
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile slide-out menu (handled by inline script below) -->
<div id="mobile-menu" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/50" id="mobile-menu-overlay"></div>
  <div class="absolute right-0 top-0 bottom-0 w-72 bg-white shadow-2xl p-6 overflow-y-auto">
    <div class="flex justify-between items-center mb-8">
      <span class="text-lg font-display font-bold text-accent-900">菜单</span>
      <button id="mobile-menu-close" class="p-2 text-accent-500 hover:text-accent-900" aria-label="关闭">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <a href="/" class="block py-3 text-accent-700 hover:text-accent-900 border-b border-accent-50">首页</a>

    <p class="mt-6 mb-2 text-xs font-medium text-accent-400 uppercase tracking-wider">按空间浏览</p>
    {spaces.map((space) => (
      <a href={`/spaces/${space.slug}`} class="block py-2.5 pl-3 text-sm text-accent-600 hover:text-accent-900 hover:bg-accent-50 rounded">
        {space.label}
      </a>
    ))}

    <p class="mt-6 mb-2 text-xs font-medium text-accent-400 uppercase tracking-wider">按风格浏览</p>
    {styles.map((style) => (
      <a href={`/styles/${style.slug}`} class="block py-2.5 pl-3 text-sm text-accent-600 hover:text-accent-900 hover:bg-accent-50 rounded">
        {style.label}
      </a>
    ))}

    <div class="mt-6 pt-4 border-t border-accent-100">
      <a href="/admin" class="block py-3 text-accent-700 hover:text-accent-900 font-medium">+ 添加案例</a>
      <a href="/about" class="block py-3 text-accent-700 hover:text-accent-900">关于</a>
      <a href="/contact" class="block py-3 text-accent-700 hover:text-accent-900">联系</a>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const close = document.getElementById('mobile-menu-close');

  if (btn && menu) {
    btn.addEventListener('click', () => menu.classList.remove('hidden'));
    overlay?.addEventListener('click', () => menu.classList.add('hidden'));
    close?.addEventListener('click', () => menu.classList.add('hidden'));
  }
</script>
