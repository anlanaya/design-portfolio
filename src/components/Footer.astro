---
import { spaces, styles } from '../data/categories';
---

<footer class="bg-accent-950 text-accent-300 pb-20 md:pb-0">
  <div class="max-w-8xl mx-auto px-4 md:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="text-xl font-display font-bold text-white tracking-tight">设计案例库</a>
        <p class="mt-3 text-sm text-accent-400 leading-relaxed">
          精选室内设计案例，按空间与风格分类，为设计师与业主提供灵感参考。
        </p>
      </div>

      <!-- 空间分类 -->
      <div>
        <h4 class="text-xs font-medium text-accent-400 uppercase tracking-wider mb-4">按空间浏览</h4>
        <ul class="space-y-2">
          {spaces.slice(0, 6).map((s) => (
            <li><a href={`/spaces/${s.slug}`} class="text-sm text-accent-300 hover:text-white transition-colors">{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- 风格分类 -->
      <div>
        <h4 class="text-xs font-medium text-accent-400 uppercase tracking-wider mb-4">按风格浏览</h4>
        <ul class="space-y-2">
          {styles.slice(0, 6).map((s) => (
            <li><a href={`/styles/${s.slug}`} class="text-sm text-accent-300 hover:text-white transition-colors">{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- 链接 -->
      <div>
        <h4 class="text-xs font-medium text-accent-400 uppercase tracking-wider mb-4">更多</h4>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-accent-300 hover:text-white transition-colors">关于我</a></li>
          <li><a href="/contact" class="text-sm text-accent-300 hover:text-white transition-colors">联系方式</a></li>
          <li><a href="/spaces/whole-house" class="text-sm text-accent-300 hover:text-white transition-colors">全屋案例</a></li>
          <li><a href="/styles/modern-minimalist" class="text-sm text-accent-300 hover:text-white transition-colors">现代极简</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-accent-800 text-xs text-accent-500">
      <p>&copy; {new Date().getFullYear()} 设计案例库. All rights reserved.</p>
    </div>
  </div>
</footer>
