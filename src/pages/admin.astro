---
import BaseLayout from '../layouts/BaseLayout.astro';
import { spaces, styles } from '../data/categories';
---

<BaseLayout
  title="管理案例"
  description="添加和管理设计案例"
>
  <div class="max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <h1 class="text-3xl md:text-4xl font-display font-bold text-accent-900 mb-4">📋 管理案例</h1>
    <p class="text-accent-500 mb-10">粘贴小红书/抖音链接，选标签，一键添加。</p>

    <!-- 表单 -->
    <div class="bg-white border border-accent-100 rounded-xl p-6 md:p-8 mb-8">
      <h2 class="text-lg font-semibold text-accent-900 mb-6">+ 添加案例</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-accent-500 mb-1">📋 案例标题 *</label>
          <input type="text" id="title" placeholder="如：纯白叙事 · 现代极简客厅"
            class="w-full px-4 py-2.5 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-accent-500 mb-1">📝 简短描述 *</label>
          <textarea id="description" rows="2" placeholder="一句话概括这个案例的特点..."
            class="w-full px-4 py-2.5 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors resize-none"></textarea>
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-accent-500 mb-1">🔗 来源链接</label>
          <input type="url" id="sourceUrl" placeholder="小红书/抖音帖子链接，直接粘贴"
            class="w-full px-4 py-2.5 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
          <div class="flex gap-2 mt-2">
            <button class="platform-btn px-3 py-1.5 border rounded-full text-xs font-medium transition-colors" data-platform="xiaohongshu">📕 小红书</button>
            <button class="platform-btn px-3 py-1.5 border rounded-full text-xs font-medium transition-colors" data-platform="douyin">🎵 抖音</button>
            <button class="platform-btn px-3 py-1.5 border rounded-full text-xs font-medium transition-colors" data-platform="original">✨ 原创</button>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-accent-500 mb-1">📐 面积（㎡）</label>
          <input type="number" id="area" placeholder="80"
            class="w-full px-4 py-2.5 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
        </div>
        <div>
          <label class="block text-sm font-medium text-accent-500 mb-1">📍 地点</label>
          <input type="text" id="location" placeholder="上海"
            class="w-full px-4 py-2.5 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-accent-500 mb-1">🖼️ 封面图 URL</label>
          <input type="url" id="cover" placeholder="https://images.unsplash.com/..."
            class="w-full px-4 py-2.5 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
        </div>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-accent-500 mb-2">🏠 空间（可多选）*</label>
        <div class="flex flex-wrap gap-2" id="spaces-tags">
          {spaces.map(space => (
            <button class="tag-btn px-3 py-1.5 border rounded-full text-xs font-medium transition-colors" data-slug={space.slug}>{space.label}</button>
          ))}
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-accent-500 mb-2">🎨 风格（可多选）*</label>
        <div class="flex flex-wrap gap-2" id="styles-tags">
          {styles.map(style => (
            <button class="tag-btn px-3 py-1.5 border rounded-full text-xs font-medium transition-colors" data-slug={style.slug}>{style.label}</button>
          ))}
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-accent-500 mb-1">🔐 管理密码</label>
        <input type="password" id="password" placeholder="输入密码"
          class="w-full max-w-xs px-4 py-2.5 border border-accent-200 rounded-lg text-sm focus:outline-none focus:border-accent-500 transition-colors">
      </div>

      <div class="flex gap-3">
        <button id="btn-save" class="px-6 py-2.5 bg-accent-900 text-white text-sm font-medium rounded-lg hover:bg-accent-800 transition-colors">
          保存案例
        </button>
        <button id="btn-reset" class="px-6 py-2.5 border border-accent-200 text-accent-600 text-sm font-medium rounded-lg hover:bg-accent-50 transition-colors">
          重置
        </button>
      </div>
      <p id="form-status" class="mt-3 text-sm hidden"></p>
    </div>

    <!-- 在线案例列表 -->
    <div class="bg-white border border-accent-100 rounded-xl p-6 md:p-8">
      <h2 class="text-lg font-semibold text-accent-900 mb-4">📂 在线案例（从 KV 加载）</h2>
      <p class="text-sm text-accent-400 mb-4" id="kv-count">加载中...</p>
      <div class="space-y-3" id="kv-list"></div>
    </div>
  </div>

  <!-- 空间标签映射，供 JS 使用 -->
  <script type="application/json" id="space-labels-json" is:inline>
    {JSON.stringify(Object.fromEntries(spaces.map(s => [s.slug, s.label])))}
  </script>
</BaseLayout>

<script src="/admin.js" is:inline></script>
