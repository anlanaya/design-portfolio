---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import { getCollection } from 'astro:content';
import { spaces, styles } from '../../data/categories';

export async function getStaticPaths() {
  return spaces.map(space => ({
    params: { space: space.slug },
    props: { space },
  }));
}

const { space } = Astro.props;

if (!space) {
  return Astro.redirect('/spaces');
}

const allCases = await getCollection('cases');

// 筛选该空间的案例
const filteredCases = allCases
  .filter(c => c.data.spaces.includes(space.slug))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

// 该空间下有哪些风格可选（用于顶部筛选标签）
const availableStyles = styles.filter(style =>
  filteredCases.some(c => c.data.styles.includes(style.slug))
);
---

<BaseLayout
  title={`${space.label} — 按空间浏览`}
  description={space.description}
>
  <div class="max-w-8xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <!-- 面包屑 -->
    <nav class="text-sm text-accent-400 mb-6">
      <a href="/spaces" class="hover:text-accent-600 transition-colors">按空间浏览</a>
      <span class="mx-2">/</span>
      <span class="text-accent-600">{space.label}</span>
    </nav>

    <!-- 页头 -->
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-display font-bold text-accent-900">
        {space.label}
      </h1>
      <p class="mt-2 text-accent-500">{space.description}</p>
      <p class="mt-1 text-sm text-accent-400">{filteredCases.length} 个案例</p>
    </div>

    <!-- 风格筛选标签 -->
    {availableStyles.length > 0 && (
      <div class="mb-8">
        <div class="flex flex-wrap gap-2">
          <span class="text-sm font-medium text-accent-500 self-center mr-1">风格:</span>
          {availableStyles.map(style => (
            <a
              href={`/styles/${style.slug}`}
              class="tag"
            >
              {style.label}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- 案例列表 -->
    {filteredCases.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredCases.map(c => <CaseCard case={c} />)}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-accent-400 text-lg">该空间暂无案例</p>
        <a href="/spaces" class="btn-outline mt-6">返回空间列表</a>
      </div>
    )}
  </div>
</BaseLayout>
