---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import { getCollection } from 'astro:content';
import { spaces } from '../../data/categories';

const allCases = await getCollection('cases');

// 统计每个空间的案例数
const spaceCounts = spaces.map(space => ({
  ...space,
  count: allCases.filter(c => c.data.spaces.includes(space.slug)).length,
}));

// 最近案例
const recentCases = allCases
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 9);
---

<BaseLayout
  title="按空间浏览"
  description="按功能空间分类浏览室内设计案例：全屋、客厅、卧室、厨餐厅、卫生间等"
>
  <div class="max-w-8xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <!-- 页头 -->
    <div class="mb-12">
      <p class="text-xs font-medium text-primary-600 uppercase tracking-wider mb-2">浏览方式</p>
      <h1 class="text-3xl md:text-4xl font-display font-bold text-accent-900">按空间浏览</h1>
      <p class="mt-3 text-accent-500 max-w-xl">选择你感兴趣的功能空间，查看对应的设计案例。</p>
    </div>

    <!-- 空间网格 -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 md:gap-4 mb-16">
      {spaceCounts.map(space => (
        <a
          href={`/spaces/${space.slug}`}
          class="group flex flex-col items-center p-5 md:p-6 rounded-xl border border-accent-100 hover:border-primary-300 hover:shadow-md transition-all duration-200 text-center"
        >
          <span class="text-2xl md:text-3xl mb-3 opacity-60 group-hover:opacity-100 transition-opacity">
            {space.slug === 'whole-house' && '🏠'}
            {space.slug === 'living-room' && '🛋️'}
            {space.slug === 'bedroom' && '🛏️'}
            {space.slug === 'kitchen-dining' && '🍳'}
            {space.slug === 'bathroom' && '🛁'}
            {space.slug === 'study' && '📚'}
            {space.slug === 'entrance' && '🚪'}
            {space.slug === 'balcony' && '🌿'}
            {space.slug === 'kids-room' && '🧸'}
            {space.slug === 'cloakroom' && '👗'}
            {space.slug === 'commercial' && '🏢'}
          </span>
          <span class="text-sm font-medium text-accent-700 group-hover:text-accent-900 transition-colors">
            {space.label}
          </span>
          <span class="text-xs text-accent-400 mt-1">{space.count} 个案例</span>
        </a>
      ))}
    </div>

    <!-- 最新案例 -->
    <section>
      <h2 class="text-xl font-display font-semibold text-accent-900 mb-8">最近发布</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentCases.map(c => <CaseCard case={c} />)}
      </div>
    </section>
  </div>
</BaseLayout>
