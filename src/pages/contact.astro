---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="联系方式"
  description="联系设计师"
>
  <div class="max-w-4xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <p class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-2">Contact</p>
    <h1 class="text-3xl md:text-4xl font-display font-bold text-accent-900 mb-12">联系方式</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- 联系信息 -->
      <div class="space-y-8">
        <div>
          <h3 class="text-xs font-medium text-accent-400 uppercase tracking-wider mb-3">微信</h3>
          <p class="text-lg text-accent-700">your_wechat_id</p>
          <p class="text-sm text-accent-400 mt-1">扫码或搜索添加</p>
        </div>

        <div>
          <h3 class="text-xs font-medium text-accent-400 uppercase tracking-wider mb-3">邮箱</h3>
          <a href="mailto:your@email.com" class="text-lg text-primary-600 hover:text-primary-700 transition-colors">
            your@email.com
          </a>
        </div>

        <div>
          <h3 class="text-xs font-medium text-accent-400 uppercase tracking-wider mb-3">社交媒体</h3>
          <div class="flex gap-4">
            <a href="#" class="btn-outline text-sm">小红书</a>
            <a href="#" class="btn-outline text-sm">抖音</a>
          </div>
        </div>
      </div>

      <!-- 二维码占位 -->
      <div class="flex items-center justify-center">
        <div class="w-48 h-48 bg-accent-50 border border-accent-100 rounded-xl flex items-center justify-center">
          <span class="text-accent-400 text-sm text-center leading-relaxed">
            微信二维码<br/>（替换为此图片）
          </span>
        </div>
      </div>
    </div>

    <!-- FAQ 提示 -->
    <div class="mt-16 p-6 bg-accent-50 rounded-xl border border-accent-100">
      <h3 class="text-sm font-medium text-accent-700 mb-2">💡 合作咨询请备注</h3>
      <ul class="text-sm text-accent-500 space-y-1 list-disc list-inside">
        <li>项目地点与面积</li>
        <li>风格偏好与预算范围</li>
        <li>预计启动时间</li>
      </ul>
    </div>
  </div>
</BaseLayout>
