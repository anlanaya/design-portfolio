---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseCard from '../components/CaseCard.astro';
import { getCollection } from 'astro:content';
import { spaces, styles } from '../data/categories';

const allCases = await getCollection('cases');
const featuredCases = allCases
  .filter(c => c.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 6);

const recentCases = allCases
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 9);
---

<BaseLayout
  title="设计案例库"
  description="精选室内设计案例，按空间与风格分类，为设计师与业主提供灵感参考"
>
  <!-- Hero Section -->
  <section class="relative bg-accent-950 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-accent-950 via-accent-900 to-accent-950 opacity-90" />
    <div class="relative max-w-8xl mx-auto px-4 md:px-8 py-20 md:py-32">
      <div class="max-w-2xl fade-in">
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-display font-bold leading-tight tracking-tight text-balance">
          发现设计灵感<br/>从空间到风格
        </h1>
        <p class="mt-6 text-lg md:text-xl text-accent-300 leading-relaxed max-w-xl">
          精选室内设计案例库，按<strong class="text-white">空间功能</strong>与<strong class="text-white">设计风格</strong>双维度分类，帮你快速找到灵感参考。
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="#browse" class="btn-primary bg-white text-accent-900 hover:bg-accent-100">
            开始浏览
            <svg class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </a>
          <a href="/about" class="btn-outline border-accent-500 text-accent-200 hover:border-white hover:text-white">
            关于我
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 双入口导航 -->
  <section id="browse" class="max-w-8xl mx-auto px-4 md:px-8 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      <!-- 按空间浏览 -->
      <div class="fade-in" style="animation-delay: 0.1s">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center text-primary-600">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="8" height="8" rx="1" /><rect x="13" y="3" width="8" height="8" rx="1" />
              <rect x="3" y="13" width="8" height="8" rx="1" /><rect x="13" y="13" width="8" height="8" rx="1" />
            </svg>
          </div>
          <h2 class="text-2xl font-display font-semibold text-accent-900">按空间浏览</h2>
        </div>
        <p class="text-accent-500 mb-6 leading-relaxed">从玄关到客厅，从卧室到阳台，按功能空间寻找对应的设计案例。</p>
        <div class="grid grid-cols-2 gap-2">
          {spaces.map((space) => (
            <a
              href={`/spaces/${space.slug}`}
              class="flex items-center gap-2 p-3 rounded-lg hover:bg-accent-50 text-accent-600 hover:text-accent-900 transition-colors group"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-primary-300 group-hover:bg-primary-500 transition-colors" />
              <span class="text-sm">{space.label}</span>
              <svg class="w-3 h-3 ml-auto opacity-0 group-hover:opacity-100 transition-opacity text-accent-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- 按风格浏览 -->
      <div class="fade-in" style="animation-delay: 0.3s">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-accent-100 flex items-center justify-center text-accent-600">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="3" /><circle cx="6" cy="6" r="2" />
              <circle cx="18" cy="6" r="2" /><circle cx="6" cy="18" r="2" /><circle cx="18" cy="18" r="2" />
            </svg>
          </div>
          <h2 class="text-2xl font-display font-semibold text-accent-900">按风格浏览</h2>
        </div>
        <p class="text-accent-500 mb-6 leading-relaxed">从现代极简到新中式，从日式侘寂到轻奢，按设计美学风格筛选案例。</p>
        <div class="grid grid-cols-2 gap-2">
          {styles.map((style) => (
            <a
              href={`/styles/${style.slug}`}
              class="flex items-center gap-2 p-3 rounded-lg hover:bg-accent-50 text-accent-600 hover:text-accent-900 transition-colors group"
            >
              <span class="w-1.5 h-1.5 rounded-full bg-accent-400 group-hover:bg-accent-600 transition-colors" />
              <span class="text-sm">{style.label}</span>
              <svg class="w-3 h-3 ml-auto opacity-0 group-hover:opacity-100 transition-opacity text-accent-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 精选案例 -->
  {featuredCases.length > 0 && (
    <section class="bg-accent-50 py-16 md:py-24">
      <div class="max-w-8xl mx-auto px-4 md:px-8">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="text-xs font-medium text-primary-600 uppercase tracking-wider mb-2">精选</p>
            <h2 class="text-2xl md:text-3xl font-display font-semibold text-accent-900">推荐案例</h2>
          </div>
          <a href="/spaces/whole-house" class="btn-ghost hidden md:inline-flex">
            查看全部
            <svg class="w-4 h-4 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredCases.map(c => <CaseCard case={c} />)}
        </div>
      </div>
    </section>
  )}

  <!-- 最近案例 -->
  <section class="max-w-8xl mx-auto px-4 md:px-8 py-16 md:py-24">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-xs font-medium text-accent-500 uppercase tracking-wider mb-2">最新</p>
        <h2 class="text-2xl md:text-3xl font-display font-semibold text-accent-900">最近发布</h2>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {recentCases.map(c => <CaseCard case={c} />)}
    </div>
  </section>
</BaseLayout>
