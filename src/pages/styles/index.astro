---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import { getCollection } from 'astro:content';
import { styles } from '../../data/categories';

const allCases = await getCollection('cases');

const styleCounts = styles.map(style => ({
  ...style,
  count: allCases.filter(c => c.data.styles.includes(style.slug)).length,
}));

const recentCases = allCases
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 9);
---

<BaseLayout
  title="按风格浏览"
  description="按设计风格分类浏览室内设计案例：现代极简、日式侘寂、北欧、新中式、轻奢等"
>
  <div class="max-w-8xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <div class="mb-12">
      <p class="text-xs font-medium text-accent-600 uppercase tracking-wider mb-2">浏览方式</p>
      <h1 class="text-3xl md:text-4xl font-display font-bold text-accent-900">按风格浏览</h1>
      <p class="mt-3 text-accent-500 max-w-xl">选择你偏好的设计美学风格，浏览对应的设计案例。</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4 mb-16">
      {styleCounts.map(style => (
        <a
          href={`/styles/${style.slug}`}
          class="group flex flex-col items-center p-5 md:p-6 rounded-xl border border-accent-100 hover:border-accent-400 hover:shadow-md transition-all duration-200 text-center"
        >
          <span class="text-2xl md:text-3xl mb-3 opacity-60 group-hover:opacity-100 transition-opacity">
            {style.slug === 'modern-minimalist' && '◻️'}
            {style.slug === 'japanese-wabisabi' && '🍵'}
            {style.slug === 'nordic' && '🪵'}
            {style.slug === 'neo-chinese' && '🏮'}
            {style.slug === 'light-luxury' && '✨'}
            {style.slug === 'industrial' && '⚙️'}
            {style.slug === 'cream-style' && '🧁'}
            {style.slug === 'original-wood' && '🪵'}
            {style.slug === 'vintage' && '📻'}
          </span>
          <span class="text-sm font-medium text-accent-700 group-hover:text-accent-900 transition-colors">
            {style.label}
          </span>
          <span class="text-xs text-accent-400 mt-1">{style.count} 个案例</span>
        </a>
      ))}
    </div>

    <section>
      <h2 class="text-xl font-display font-semibold text-accent-900 mb-8">最近发布</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentCases.map(c => <CaseCard case={c} />)}
      </div>
    </section>
  </div>
</BaseLayout>
