---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import { getCollection } from 'astro:content';
import { styles, spaces } from '../../data/categories';

export async function getStaticPaths() {
  return styles.map(style => ({
    params: { style: style.slug },
    props: { style },
  }));
}

const { style } = Astro.props;

if (!style) {
  return Astro.redirect('/styles');
}

const allCases = await getCollection('cases');

const filteredCases = allCases
  .filter(c => c.data.styles.includes(style.slug))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

// 该风格下有哪些空间可选
const availableSpaces = spaces.filter(space =>
  filteredCases.some(c => c.data.spaces.includes(space.slug))
);
---

<BaseLayout
  title={`${style.label} — 按风格浏览`}
  description={style.description}
>
  <div class="max-w-8xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <nav class="text-sm text-accent-400 mb-6">
      <a href="/styles" class="hover:text-accent-600 transition-colors">按风格浏览</a>
      <span class="mx-2">/</span>
      <span class="text-accent-600">{style.label}</span>
    </nav>

    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-display font-bold text-accent-900">
        {style.label}
      </h1>
      <p class="mt-2 text-accent-500">{style.description}</p>
      <p class="mt-1 text-sm text-accent-400">{filteredCases.length} 个案例</p>
    </div>

    {availableSpaces.length > 0 && (
      <div class="mb-8">
        <div class="flex flex-wrap gap-2">
          <span class="text-sm font-medium text-accent-500 self-center mr-1">空间:</span>
          {availableSpaces.map(space => (
            <a href={`/spaces/${space.slug}`} class="tag">
              {space.label}
            </a>
          ))}
        </div>
      </div>
    )}

    {filteredCases.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filteredCases.map(c => <CaseCard case={c} />)}
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-accent-400 text-lg">该风格暂无案例</p>
        <a href="/styles" class="btn-outline mt-6">返回风格列表</a>
      </div>
    )}
  </div>
</BaseLayout>
